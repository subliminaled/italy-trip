---
// No props needed for static map
---
<section class="section" id="map">
  <div class="section-header">
    <h2>Route Map</h2>
  </div>
  <div class="section-body">
    <svg class="route-map" viewBox="0 0 980 320" role="img" aria-label="Italy trip route map from Rome to Milan">
      <defs>
        <linearGradient id="sea" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#f8f3eb" />
          <stop offset="100%" stop-color="#efe6d8" />
        </linearGradient>
      </defs>
      <rect x="0" y="0" width="980" height="320" fill="url(#sea)" rx="18" />
      <path d="M590 34 C565 70, 545 95, 535 130 C525 160, 535 195, 520 222 C506 246, 480 266, 452 284 C430 298, 422 308, 430 318 L595 318 C620 300, 635 280, 646 255 C659 226, 657 190, 669 160 C681 130, 708 110, 724 84 C740 58, 743 36, 736 18 Z" fill="#e7dccb" stroke="#cdbda7" stroke-width="3"/>
      <path d="M472 282 C490 260, 515 238, 526 210 C540 172, 540 134, 560 100" fill="none" stroke="#9a3412" stroke-width="6" stroke-linecap="round"/>
      <path d="M560 100 C610 85, 656 72, 707 52" fill="none" stroke="#9a3412" stroke-width="6" stroke-linecap="round"/>
      <g fill="#9a3412" stroke="#fffdf9" stroke-width="4">
        <circle cx="560" cy="100" r="10" />
        <circle cx="600" cy="84" r="10" />
        <circle cx="483" cy="250" r="10" />
        <circle cx="555" cy="66" r="10" />
        <circle cx="622" cy="45" r="10" />
      </g>
      <g font-family="Inter, sans-serif" font-size="22" font-weight="700" fill="#1f2937">
        <text x="575" y="95">Rome</text>
        <text x="616" y="80">Florence</text>
        <text x="300" y="250">Cinque Terre</text>
        <text x="506" y="58">Varenna</text>
        <text x="638" y="40">Milan</text>
      </g>
      <g font-family="Inter, sans-serif" font-size="15" fill="#6b7280">
        <text x="574" y="118">Apr 10–12</text>
        <text x="616" y="103">Apr 12–15</text>
        <text x="301" y="273">Apr 15–17</text>
        <text x="505" y="81">Apr 17–18</text>
        <text x="638" y="63">Apr 18–19</text>
      </g>
    </svg>
    <p class="meta" style="margin-top:10px;">Route: Rome → Florence → Cinque Terre (Monterosso) → Varenna (Lake Como) → Milan</p>
  </div>
</section>
