---
const { title = "Italy Family Trip – April 2026" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f7f3ec;
        --paper: #fffdf9;
        --ink: #1f2937;
        --muted: #6b7280;
        --accent: #9a3412;
        --accent-soft: #f3e8df;
        --line: #e7ded3;
        --shadow: 0 10px 30px rgba(31, 41, 55, 0.08);
        --radius: 20px;
        --max: 1100px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: linear-gradient(180deg, #f3eee6 0%, #f8f5ef 30%, #f7f3ec 100%);
        color: var(--ink);
        line-height: 1.5;
      }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: var(--max); margin: 0 auto; padding: 24px 20px 56px; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
      .brand { font-size:.95rem; font-weight:700; color:var(--accent); }
      .nav { display:flex; flex-wrap:wrap; gap:8px; }
      .nav a { padding:8px 12px; border-radius:999px; background:rgba(255,255,255,.55); border:1px solid var(--line); font-size:.92rem; color:var(--muted); }
      .hero, .section {
        background: var(--paper);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }
      .hero {
        border-radius: 28px;
        padding: 32px;
        position: relative;
        overflow: hidden;
      }
      .hero::after {
        content: "";
        position: absolute;
        inset: auto -80px -80px auto;
        width: 240px;
        height: 240px;
        background: radial-gradient(circle, rgba(154, 52, 18, 0.12) 0%, rgba(154, 52, 18, 0) 70%);
      }
      .eyebrow {
        display:inline-block; padding:6px 10px; border-radius:999px; background:var(--accent-soft);
        color:var(--accent); font-size:.85rem; font-weight:700; letter-spacing:.02em; margin-bottom:14px;
      }
      h1 { margin:0 0 8px; font-size: clamp(2rem, 5vw, 3.7rem); line-height:1.05; letter-spacing:-.04em; }
      .sub { margin:0; color:var(--muted); font-size:1.05rem; max-width:66ch; }
      .summary-grid, .travel-grid, .city-grid, .page-links {
        display:grid; gap:14px;
      }
      .summary-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); margin-top:24px; }
      .summary-card, .travel-card, .city-card, .page-card {
        background:#faf7f1; border:1px solid var(--line); border-radius:18px; padding:16px 18px;
      }
      .summary-card .label { display:block; color:var(--muted); font-size:.82rem; margin-bottom:6px; }
      .section { margin-top:24px; border-radius:var(--radius); overflow:hidden; }
      .section-header { padding:22px 24px 10px; }
      .section-header h2 { margin:0; font-size:1.45rem; letter-spacing:-.02em; }
      .section-header p { margin:6px 0 0; color:var(--muted); }
      .section-body { padding: 0 24px 24px; }
      .travel-grid, .city-grid, .page-links { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .flight { padding: 12px 0; border-top:1px solid var(--line); }
      .flight:first-of-type { border-top:0; padding-top:0; }
      .flight strong { display:block; }
      .flight span, .meta { color:var(--muted); display:block; margin-top:4px; }
      .timeline { padding: 0 24px 24px; }
      .stop { display:grid; grid-template-columns:140px 1fr; gap:18px; padding:18px 0; border-top:1px solid var(--line); }
      .stop:first-child { border-top:0; }
      .date { font-weight:700; color:var(--accent); font-size:.95rem; }
      .city { margin:0 0 6px; font-size:1.2rem; }
      .pill-row { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
      .pill {
        display:inline-flex; align-items:center; border:1px solid var(--line); background:#faf7f1;
        border-radius:999px; padding:8px 12px; font-size:.92rem;
      }
      .city-card h3, .page-card h3 { margin:0 0 8px; font-size:1.15rem; }
      .city-card p, .page-card p { margin:6px 0; color:var(--muted); }
      .city-card ul { margin:10px 0 0; padding-left:18px; }
      .city-card li { margin:4px 0; }
      .route-map {
        width: 100%;
        background: linear-gradient(180deg, #fbf8f2 0%, #f7f2ea 100%);
        border:1px solid var(--line);
        border-radius:18px;
        padding:16px;
      }
      .page-card { transition: transform .15s ease, box-shadow .15s ease; }
      .page-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
      footer { text-align:center; color:var(--muted); font-size:.9rem; margin-top:18px; }
      @media (max-width: 900px) {
        .summary-grid, .travel-grid, .city-grid, .page-links, .stop { grid-template-columns:1fr; }
      }
      @media (max-width: 780px) {
        .hero, .section-header, .timeline, .section-body { padding-left:18px; padding-right:18px; }
        .stop { gap:8px; }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="topbar">
        <div class="brand"><a href={`./`}>Italy Trip · April 2026</a></div>
        <nav class="nav">
          <a href={`./#map`}>Map</a>
          <a href={`./#flights`}>Flights</a>
          <a href={`./#itinerary`}>Itinerary</a>
          <a href={`./#cities`}>Cities</a>
        </nav>
      </div>
      <slot />
      <footer>Built with Astro for easy Git-based updates and GitHub Pages deployment.</footer>
    </main>
  </body>
</html>
