---
import CityLayout from "../../layouts/CityLayout.astro";
import { cities } from "../../data/trip.js";
import { hotels } from "../../data/hotels.js";
---
<CityLayout
  title={`${hotels.find(h => h.city === "Cinque Terre").city} – Italy Family Trip`}
  city={hotels.find(h => h.city === "Cinque Terre").city}
  stay={`${hotels.find(h => h.city === "Cinque Terre").dates} · ${hotels.find(h => h.city === "Cinque Terre").nights} night${hotels.find(h => h.city === "Cinque Terre").nights > 1 ? 's' : ''}`}
  hotel={hotels.find(h => h.city === "Cinque Terre").name}
>
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Base town: {hotels.find(h => h.city === "Cinque Terre").town}</li>
        <li>Hotel: {hotels.find(h => h.city === "Cinque Terre").name}</li>
        <li>{hotels.find(h => h.city === "Cinque Terre").nights} nights</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Description</h3>
      <ul>
        <li>{cities.find(c => c.name === "Cinque Terre").description}</li>
      </ul>
    </article>
  </div>
</CityLayout>
