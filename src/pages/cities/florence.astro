---
import CityLayout from "../../layouts/CityLayout.astro";
---
<CityLayout title="Florence – Italy Family Trip" city="Florence" stay="Apr 12–15 · 3 nights" hotel="Hotel Collodi">
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Hotel: Hotel Collodi</li>
        <li>3 nights in Florence</li>
        <li>Central base for city exploration</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Tuscany day-trip plan</h3>
      <ul>
        <li>Planning a local train day trip to one or two Tuscany towns</li>
        <li>Lucca is a strong train-friendly option</li>
        <li>Pisa is easy to pair with Lucca if wanted</li>
      </ul>
    </article>
  </div>
</CityLayout>
