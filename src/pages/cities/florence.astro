---
import CityLayout from "../../layouts/CityLayout.astro";
import { cities } from "../../data/trip.js";
import { hotels } from "../../data/hotels.js";
---
<CityLayout
  title={`${hotels.find(h => h.city === "Florence").city} – Italy Family Trip`}
  city={hotels.find(h => h.city === "Florence").city}
  stay={`${hotels.find(h => h.city === "Florence").dates} · ${hotels.find(h => h.city === "Florence").nights} night${hotels.find(h => h.city === "Florence").nights > 1 ? 's' : ''}`}
  hotel={hotels.find(h => h.city === "Florence").name}
>
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Hotel: {hotels.find(h => h.city === "Florence").name}</li>
        <li>{hotels.find(h => h.city === "Florence").nights} nights in Florence</li>
        <li>Central base for city exploration</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Description</h3>
      <ul>
        <li>{cities.find(c => c.name === "Florence").description}</li>
      </ul>
    </article>
  </div>
</CityLayout>
