---
import CityLayout from "../../layouts/CityLayout.astro";
import { cities } from "../../data/trip.js";
---
<CityLayout title="Lake Como – Italy Family Trip" city="Lake Como" stay="Apr 17–18 · 1 night" hotel="Albergo Milano">
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Base town: Varenna</li>
        <li>Hotel: Albergo Milano</li>
        <li>1 night</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Description</h3>
      <ul>
        <li>{cities.find(c => c.name === "Lake Como").description}</li>
      </ul>
    </article>
  </div>
</CityLayout>
