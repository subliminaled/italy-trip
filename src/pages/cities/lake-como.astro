---
import CityLayout from "../../layouts/CityLayout.astro";
import { cities } from "../../data/trip.js";
import { hotels } from "../../data/hotels.js";
import { reservations } from "../../data/reservations.js";
---
<CityLayout
  title={`${hotels.find(h => h.city === "Lake Como").city} – Italy Family Trip`}
  city={hotels.find(h => h.city === "Lake Como").city}
  stay={`${hotels.find(h => h.city === "Lake Como").dates} · ${hotels.find(h => h.city === "Lake Como").nights} night${hotels.find(h => h.city === "Lake Como").nights > 1 ? 's' : ''}`}
  hotel={hotels.find(h => h.city === "Lake Como").name}
>
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Base town: {hotels.find(h => h.city === "Lake Como").town}</li>
        <li>Hotel: <a href={hotels.find(h => h.city === "Lake Como").url} target="_blank"> {hotels.find(h => h.city === "Lake Como").name}</a></li>
        <li>{hotels.find(h => h.city === "Lake Como").nights} night</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Description</h3>
      <ul>
        <li>{cities.find(c => c.name === "Lake Como").description}</li>
      </ul>
    </article>
    {reservations.find(r => r.city === "Lake Como") && (
      <article class="city-card">
        <h3>Booked reservation</h3>
        <ul>
          <li><strong>{reservations.find(r => r.city === "Lake Como").name}</strong></li>
          <li>Date: {reservations.find(r => r.city === "Lake Como").date}</li>
          <li>Time: {reservations.find(r => r.city === "Lake Como").time}</li>
          <li>{reservations.find(r => r.city === "Lake Como").description}</li>
        </ul>
      </article>
    )}
  </div>
</CityLayout>
