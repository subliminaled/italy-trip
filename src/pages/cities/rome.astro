import CityLayout from "../../layouts/CityLayout.astro";
import { cities } from "../../data/trip.js";
<CityLayout title="Rome – Italy Family Trip" city="Rome" stay="Apr 10–12 · 2 nights" hotel="Vatican Jubilee">
  <div class="city-grid">
    <article class="city-card">
      <h3>Stay</h3>
      <ul>
        <li>Arrive April 10 via Amsterdam</li>
        <li>Hotel: Vatican Jubilee</li>
        <li>2 nights in Rome</li>
      </ul>
    </article>
    <article class="city-card">
      <h3>Description</h3>
      <ul>
        <li>{cities.find(c => c.name === "Rome").description}</li>
      </ul>
    </article>
  </div>
</CityLayout>
