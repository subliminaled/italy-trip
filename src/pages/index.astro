---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tripInfo } from "../data/trip.js";
import { flights } from "../data/flights.js";
import { hotels } from "../data/hotels.js";
import { reservations } from "../data/reservations.js";
import RouteMap from "../components/RouteMap.astro";
import InteractiveMap from "../components/InteractiveMap.astro";
---
<BaseLayout title="Italy Family Trip – April 2026">
    <InteractiveMap />
  
  <section class="section" id="flights">
    <div class="section-header">
      <h2>Air Travel</h2>
      <p>Flight schedule currently booked.</p>
    </div>
    <div class="section-body">
      <div class="travel-grid">
        {flights.map(flight => (
          <article class="travel-card">
            <h3>{flight.direction}</h3>
            {flight.segments.map(segment => (
              <div class="flight">
                <strong>{segment.date} — {segment.flight}</strong>
                <span>{segment.from} → {segment.to}</span>
                <span>Departs {segment.departs}</span>
                <span>Arrives {segment.arrives}</span>
              </div>
            ))}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="itinerary">
    <div class="section-header">
      <h2>Trip Itinerary</h2>
      <p>Hotels, dates, and booked travel sites.</p>
    </div>
    <div class="timeline">
      {hotels.map(hotel => {
        const reservation = reservations.find(r => r.city === hotel.city);
        return (
          <article class="stop">
            <div class="date">{hotel.dates}</div>
            <div>
              <h3 class="city">{hotel.city} · {hotel.nights} night{hotel.nights > 1 ? 's' : ''}</h3>
              {hotel.town && <span class="meta"><strong>City/Town:</strong> {hotel.town}</span>}
              <span class="meta"><strong>Hotel:</strong> {hotel.name}</span>
              {reservation && (
                <strong>Booked Reservations:</strong><br/>
                <div class="pill-row">
                  <span class="pill">
                    {reservation.name}<br/>
                    {reservation.description} <br/>
                    {reservation.date} at {reservation.time}
                  </span>
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Train Segments</h2>
      <p>Primary rail connections between cities.</p>
    </div>
    <div class="section-body">
      <div class="city-grid">
        <article class="city-card">
          <h3>Rome → Florence</h3>
          <ul>
            <li>High-speed train (Frecciarossa or Italo)</li>
            <li>Approx travel time: 1h 30m</li>
            <li>Depart: Roma Termini</li>
            <li>Arrive: Firenze Santa Maria Novella</li>
          </ul>
        </article>

        <article class="city-card">
          <h3>Florence → Cinque Terre</h3>
          <ul>
            <li>Train to Monterosso al Mare</li>
            <li>Approx travel time: 2h 30m</li>
            <li>Connection often in Pisa or La Spezia</li>
          </ul>
        </article>

        <article class="city-card">
          <h3>Cinque Terre → Varenna (Lake Como)</h3>
          <ul>
            <li>Route via Milan</li>
            <li>Approx travel time: 4–4.5 hours</li>
            <li>Change trains in Milano Centrale</li>
          </ul>
        </article>

        <article class="city-card">
          <h3>Varenna → Milan</h3>
          <ul>
            <li>Direct regional train</li>
            <li>Approx travel time: 1 hour</li>
            <li>Depart: Varenna-Esino</li>
            <li>Arrive: Milano Centrale</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="cities">
    <div class="section-header">
      <h2>City Pages</h2>
    </div>
    <div class="section-body">
      <div class="page-links">
        <a class="page-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cities/rome/`}>
          <h3>Rome</h3>
          <p>Hotel, Vatican reservation, and the Rome segment.</p>
        </a>
        <a class="page-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cities/florence/`}>
          <h3>Florence</h3>
          <p>Includes the Tuscany local train day-trip note.</p>
        </a>
        <a class="page-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cities/cinque-terre/`}>
          <h3>Cinque Terre</h3>
          <p>Monterosso base and short coastal stay details.</p>
        </a>
        <a class="page-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cities/lake-como/`}>
          <h3>Lake Como</h3>
          <p>Varenna stay and Villa del Balbianello reservation.</p>
        </a>
        <a class="page-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/cities/milan/`}>
          <h3>Milan</h3>
          <p>Final night, Duomo area, and flight-out note.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
